# Frontend
# Vite exposes vars prefixed with VITE_ to the client
VITE_API_URL=http://localhost:5000

# Backend
PORT=5000
NODE_ENV=production

# Postgres (docker-compose)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=procurepro

# WhatsApp Cloud API
# ВАЖНО: не коммитьте реальные токены. Используйте .env локально/на сервере.
WHATSAPP_MOCK_MODE=false
WHATSAPP_API_URL=https://graph.facebook.com/v22.0
WHATSAPP_API_TOKEN=REPLACE_ME
# phone_number_id from Meta (НЕ ваш номер телефона)
WHATSAPP_PHONE_ID=REPLACE_ME
WHATSAPP_VERIFY_TOKEN=procurepro_verify_token

# Если задано — все сообщения при анализе будут отправляться на этот номер (для теста)
# Пример: 77072303223
WHATSAPP_TEST_NUMBER=

# (опционально) публичный URL фронта для ссылок в сообщениях поставщикам
# Пример: http://82.115.42.79
FRONTEND_URL=
