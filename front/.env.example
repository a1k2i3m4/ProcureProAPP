# Пример переменных окружения для фронтенда (Vite)
#
# ЛОКАЛЬНО:
#   скопируйте в front/.env.local (этот файл не коммитится)
#
# DOCKER:
#   docker-compose.yml прокидывает VITE_API_URL как build-arg

# API base URL.
# В проде рекомендуем "/api-procurepro" (Nginx внутри контейнера проксирует на backend)
VITE_API_URL=/api-procurepro

# Совместимость с формулировкой "REACT_APP_API_URL" в требованиях.
# В Vite переменные окружения доступны только с префиксом VITE_, поэтому используем алиас:
#   REACT_APP_API_URL -> VITE_REACT_APP_API_URL
VITE_REACT_APP_API_URL=

# SSO / Central Auth
# URL страницы логина основного приложения (AuthService/app picker)
VITE_AUTH_LOGIN_URL=https://manager.cucrm.kz

# Base URL AuthService (нужен для обмена sessionId -> token)
# Пример (prod): https://manager.cucrm.kz
VITE_AUTH_SERVICE_URL=https://manager.cucrm.kz

