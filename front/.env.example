# Пример переменных окружения для фронтенда (Vite)
#
# ЛОКАЛЬНО:
#   скопируйте в front/.env.local (этот файл не коммитится)
#
# DOCKER:
#   docker-compose.yml прокидывает VITE_API_URL как build-arg

# API base URL.
# В проде рекомендуем "/api" (Nginx внутри контейнера проксирует на backend)
VITE_API_URL=/api

