# ProcurePro Backend - Docker environment
# Common variables loaded from .env.shared

PORT=5001

# Database
DB_HOST=procurepro-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=123456qwerty
DB_NAME=procurepro

# 1C integration shared API key
ONEC_API_KEY=procurepro-1c-secret-key

# WMS sync source (reporting-service)
REPORTING_SERVICE_URL=http://reporting-service:3100
# Optional overrides
# WMS_REQUEST_TIMEOUT_MS=30000
# WMS_SYNC_INTERVAL_MS=86400000

